# OAN Backend Configuration

# Fireworks AI (for agent reasoning)
FIREWORKS_API_KEY=your-fireworks-api-key-here
# Optional: specify a different model (defaults to llama-v3-70b-instruct)
# FIREWORKS_MODEL=accounts/fireworks/models/llama-v3-70b-instruct

# Platform settings
PLATFORM_FEE_PERCENT=1.0
L402_TASK_BOARD_COST_SATS=1

# Database (Supabase)
# Get these from: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# MoneyDevKit Agent Wallet
# Run: npx @moneydevkit/agent-wallet@latest init
# The daemon runs on port 3456 by default
MDK_WALLET_PORT=3456
